# 环境变量配置

# 复制此文件为 .env 并填入真实值

# ========== 百度OCR ==========
BAIDU_API_KEY=你的百度APIKey
BAIDU_SECRET_KEY=你的百度SecretKey

# 获取方式:
# 1. 访问 https://console.bce.baidu.com/
# 2. 注册/登录
# 3. 创建应用 -> 选择"文字识别"
# 4. 获取 API Key 和 Secret Key

# ========== 微信支付 ==========
WECHAT_MCH_ID=你的商户号
WECHAT_API_KEY=你的API密钥
WECHAT_APP_ID=你的小程序AppID
WECHAT_APP_SECRET=你的小程序AppSecret
WECHAT_NOTIFY_URL=https://你的域名/api/payment/notify

# 获取方式:
# 1. 微信公众平台: https://mp.weixin.qq.com/
# 2. 开通小程序
# 3. 微信支付商户平台: https://pay.weixin.qq.com/

# ========== Redis (可选) ==========
REDIS_URL=redis://localhost:6379
