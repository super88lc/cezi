{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "timeout": 60
      }
    },
    {
      "src": "templates/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "templates/admin.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/admin",
      "dest": "/templates/admin.html"
    },
    {
      "src": "/",
      "dest": "/templates/index.html"
    }
  ]
}
